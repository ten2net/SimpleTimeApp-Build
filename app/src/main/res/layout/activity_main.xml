<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="16dp">

    <!-- 时间显示 -->
    <TextView
        android:id="@+id/timeTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2024-01-01 00:00:00"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:padding="24dp"
        android:background="@drawable/bg_time_card"
        android:layout_marginBottom="24dp" />

    <!-- 功能按钮网格 -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        android:layout_marginBottom="24dp">

        <!-- WiFi按钮 -->
        <Button
            android:id="@+id/wifiButton"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="WiFi\n已关闭"
            android:textSize="14sp"
            android:drawableTop="@drawable/ic_wifi"
            android:paddingTop="16dp"
            android:background="@drawable/bg_function_button"
            android:textColor="#333333" />

        <!-- 移动数据按钮 -->
        <Button
            android:id="@+id/dataButton"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="移动数据\n已关闭"
            android:textSize="14sp"
            android:drawableTop="@drawable/ic_data"
            android:paddingTop="16dp"
            android:background="@drawable/bg_function_button"
            android:textColor="#333333" />

        <!-- GPS按钮 -->
        <Button
            android:id="@+id/gpsButton"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="GPS\n已关闭"
            android:textSize="14sp"
            android:drawableTop="@drawable/ic_gps"
            android:paddingTop="16dp"
            android:background="@drawable/bg_function_button"
            android:textColor="#333333" />

        <!-- 关机按钮 -->
        <Button
            android:id="@+id/shutdownButton"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="一键关机"
            android:textSize="14sp"
            android:drawableTop="@drawable/ic_power"
            android:paddingTop="16dp"
            android:background="@drawable/bg_shutdown_button"
            android:textColor="#FFFFFF" />

    </GridLayout>

    <!-- 亮度调节 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_brightness_card"
        android:padding="16dp">

        <TextView
            android:id="@+id/brightnessLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="亮度调节: 50%"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/brightnessSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="255"
            android:progress="128"
            android:progressTint="#1677FF"
            android:thumbTint="#1677FF" />

    </LinearLayout>

</LinearLayout>
