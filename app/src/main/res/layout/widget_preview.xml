<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_widget"
    android:padding="8dp"
    android:gravity="center">

    <!-- WiFi按钮预览 -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:src="@drawable/ic_wifi"
        android:background="@drawable/bg_widget_button"
        android:padding="12dp"
        android:contentDescription="WiFi" />

    <!-- 移动数据按钮预览 -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:src="@drawable/ic_data"
        android:background="@drawable/bg_widget_button"
        android:padding="12dp"
        android:contentDescription="数据" />

    <!-- GPS按钮预览 -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:src="@drawable/ic_gps"
        android:background="@drawable/bg_widget_button"
        android:padding="12dp"
        android:contentDescription="GPS" />

    <!-- 亮度按钮预览 -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:src="@drawable/ic_brightness_medium"
        android:background="@drawable/bg_widget_button"
        android:padding="12dp"
        android:contentDescription="亮度" />

    <!-- 关机按钮预览 -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:src="@drawable/ic_power"
        android:background="@drawable/bg_widget_button_shutdown"
        android:padding="12dp"
        android:contentDescription="关机" />

</LinearLayout>