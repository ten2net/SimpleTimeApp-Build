<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="16dp">

    <!-- 时间显示 -->
    <TextView
        android:id="@+id/timeTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2024-01-01 00:00:00"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:padding="20dp"
        android:background="@drawable/bg_time_card"
        android:layout_marginBottom="16dp" />

    <!-- 功能按钮网格 2x2 -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false">

        <!-- WiFi按钮 -->
        <Button
            android:id="@+id/wifiButton"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="WiFi\n已关闭"
            android:textSize="14sp"
            android:drawableTop="@drawable/ic_wifi"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:background="@drawable/bg_function_button"
            android:textColor="#333333"
            android:elevation="2dp" />

        <!-- 移动数据按钮 -->
        <Button
            android:id="@+id/dataButton"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="移动数据\n已关闭"
            android:textSize="14sp"
            android:drawableTop="@drawable/ic_data"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:background="@drawable/bg_function_button"
            android:textColor="#333333"
            android:elevation="2dp" />

        <!-- GPS按钮 -->
        <Button
            android:id="@+id/gpsButton"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="GPS\n已关闭"
            android:textSize="14sp"
            android:drawableTop="@drawable/ic_gps"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:background="@drawable/bg_function_button"
            android:textColor="#333333"
            android:elevation="2dp" />

        <!-- 亮度调节按钮 -->
        <Button
            android:id="@+id/brightnessButton"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="6dp"
            android:text="亮度\n自定义"
            android:textSize="14sp"
            android:drawableTop="@drawable/ic_brightness_medium"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:background="@drawable/bg_brightness_button"
            android:textColor="#333333"
            android:elevation="2dp" />

    </GridLayout>

    <!-- 关机按钮 -->
    <Button
        android:id="@+id/shutdownButton"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="8dp"
        android:text="一键关机"
        android:textSize="18sp"
        android:textStyle="bold"
        android:drawableTop="@drawable/ic_power"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_shutdown_button"
        android:textColor="#FFFFFF"
        android:elevation="2dp" />

</LinearLayout>
